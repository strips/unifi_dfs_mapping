# Copy this file to `secrets/secrets.env`. The real file is gitignored.
#
# These values are loaded by docker compose via `env_file:` and become
# environment variables inside the container. They are NEVER read from
# the YAML config and never written to logs.

# Local-only UniFi admin (Network → Settings → Admins → "Restrict to
# local access only"). Required if scan.enabled=true.
UNIFI_USERNAME=
UNIFI_PASSWORD=

# Only used if you start the optional bundled Grafana profile
# (docker compose --profile viz up). If you point the dashboards at your
# existing Grafana instead, you don't need this.
GF_SECURITY_ADMIN_PASSWORD=
