# Defaults; override in .env (this file is checked in, .env is not).
# Nothing in here is a secret — secrets live in secrets/secrets.env.

# UID/GID the container should run as. Should match `id -u` / `id -g`
# on the host so the bind-mounted ./data is writable.
PUID=1000
PGID=1000

# Host port for syslog (UniFi default is 514). The container always
# listens on 5514 internally.
FJORD_HOST_PORT=514

# Host port for the built-in stats web page.
FJORD_WEB_PORT=8080

# Where SQLite + CSV are written on the host.
FJORD_DATA_DIR=./data

# Log verbosity: DEBUG, INFO, WARNING, ERROR
FJORD_LOG_LEVEL=INFO

# Credentials (UNIFI_USERNAME, UNIFI_PASSWORD) belong in secrets/secrets.env,
# not here. See secrets/secrets.example.env.